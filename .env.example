# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001/api
VITE_API_TIMEOUT=10000

# Pusher — temps réel (dashboard, notifications, liste assurés, chat support)
# Créer un compte sur https://pusher.com → Channels → créer une app
VITE_PUSHER_APP_KEY=your_pusher_app_key
VITE_PUSHER_CLUSTER=eu

# Optionnel — Chatbot vocal ElevenLabs
VITE_ELEVENLABS_AGENT_ID=
VITE_ELEVENLABS_API_KEY=

# Optionnel — Claude AI (console.anthropic.com)
VITE_ANTHROPIC_API_KEY=

# ─── Docker / Backend ─────────────────────────────────────────────────────────
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_strong_password
POSTGRES_DB=assurance_db

# JWT — générer avec : openssl rand -base64 64
JWT_SECRET=your_very_long_random_base64_secret_minimum_64_chars
JWT_EXPIRATION_MS=86400000

# CORS — domaine(s) frontend autorisé(s), séparés par des virgules
ALLOWED_ORIGINS=http://localhost:5173,https://your-production-domain.com

# Comptes administrateurs initiaux (séparés par des virgules)
ADMIN_EMAILS=admin@votre-domaine.com
ADMIN_DEFAULT_PASSWORD=ChangeMe!2024

# Optionnel — envoi d'emails
MAIL_USERNAME=
MAIL_PASSWORD=
